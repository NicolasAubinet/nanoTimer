<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
   android:orientation="vertical"
   android:layout_width="match_parent"
   android:layout_height="wrap_content"
   android:paddingLeft="16dp"
   android:paddingRight="16dp"
   android:paddingTop="16dp"
   android:paddingBottom="2dp">

  <TextView
     android:layout_width="wrap_content"
     android:layout_height="wrap_content"
     android:text="@string/cross_neutrality"
     android:textAllCaps="true"
     android:textColor="@color/secondary_text"
     android:textSize="12sp"
     android:letterSpacing="0.08"
     android:layout_marginBottom="6dp"/>

  <!-- Segmented control (Specific / Dual / Full), populated in code. -->
  <LinearLayout
     android:id="@+id/llCrossModeSeg"
     android:orientation="horizontal"
     android:background="@drawable/cross_segment_container"
     android:padding="3dp"
     android:layout_width="match_parent"
     android:layout_height="wrap_content"/>

  <LinearLayout
     android:id="@+id/llCrossFace"
     android:orientation="vertical"
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:layout_marginTop="14dp">

    <TextView
       android:layout_width="wrap_content"
       android:layout_height="wrap_content"
       android:text="@string/cross_face"
       android:textAllCaps="true"
       android:textColor="@color/secondary_text"
       android:textSize="12sp"
       android:letterSpacing="0.08"
       android:layout_marginBottom="6dp"/>

    <!-- Row of 6 color swatches, populated in code. -->
    <LinearLayout
       android:id="@+id/llCrossSwatches"
       android:orientation="horizontal"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"/>

  </LinearLayout>

  <ScrollView
     android:layout_width="match_parent"
     android:layout_height="wrap_content"
     android:layout_marginTop="16dp"
     android:minHeight="48dp">

    <LinearLayout
       android:id="@+id/llCrossResults"
       android:orientation="vertical"
       android:layout_width="match_parent"
       android:layout_height="wrap_content"/>

  </ScrollView>

</LinearLayout>
