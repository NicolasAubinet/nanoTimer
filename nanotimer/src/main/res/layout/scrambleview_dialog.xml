<?xml version="1.0" encoding="utf-8"?>
<!-- Host for the on-demand scramble diagram. The WebView is transparent and blends
     onto the card background; a text fallback is shown if rendering is unavailable. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

  <WebView
      android:id="@+id/wvScramble"
      android:layout_width="match_parent"
      android:layout_height="300dp"
      android:background="@android:color/transparent"/>

  <TextView
      android:id="@+id/tvScrambleFallback"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="4dp"
      android:gravity="center"
      android:padding="12dp"
      android:textSize="15sp"
      android:textColor="@color/secondary_text"
      android:visibility="gone"/>

</LinearLayout>
