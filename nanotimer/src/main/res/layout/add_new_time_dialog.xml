<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
   xmlns:app="http://schemas.android.com/apk/res-auto"
   android:orientation="vertical"
   android:gravity="center_horizontal"
   android:layout_width="match_parent"
   android:layout_height="wrap_content"
   android:paddingLeft="24dp"
   android:paddingRight="24dp"
   android:paddingTop="18dp"
   android:paddingBottom="8dp">

   <TextView
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:text="@string/select_time_to_add"
      android:textColor="@color/secondary_text"
      android:textSize="14sp"
      android:layout_marginBottom="18dp"/>

   <LinearLayout
      android:orientation="horizontal"
      android:gravity="center"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content">

      <LinearLayout
         android:orientation="vertical"
         android:gravity="center"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content">
         <EditText
            android:id="@+id/tfMinutes"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/dialog_time_field"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:maxLength="2"
            android:nextFocusForward="@+id/tfSeconds"
            style="@style/NumericEditText"/>
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/time_unit_min"
            android:textColor="@color/secondary_text"
            android:textSize="11sp"/>
      </LinearLayout>

      <LinearLayout
         android:orientation="vertical"
         android:gravity="center"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content">
         <TextView
            android:layout_width="20dp"
            android:layout_height="58dp"
            android:gravity="center"
            android:text=":"
            android:textColor="@color/secondary_text"
            android:textSize="24sp"/>
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=" "
            android:textSize="11sp"/>
      </LinearLayout>

      <LinearLayout
         android:orientation="vertical"
         android:gravity="center"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content">
         <EditText
            android:id="@+id/tfSeconds"
            android:layout_width="58dp"
            android:layout_height="58dp"
            android:background="@drawable/dialog_time_field"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:maxLength="2"
            android:nextFocusForward="@+id/tfHundreds"
            style="@style/NumericEditText"/>
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/time_unit_sec"
            android:textColor="@color/secondary_text"
            android:textSize="11sp"/>
      </LinearLayout>

      <LinearLayout
         android:orientation="vertical"
         android:gravity="center"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content">
         <TextView
            android:layout_width="20dp"
            android:layout_height="58dp"
            android:gravity="center"
            android:text="."
            android:textColor="@color/secondary_text"
            android:textSize="24sp"/>
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text=" "
            android:textSize="11sp"/>
      </LinearLayout>

      <LinearLayout
         android:orientation="vertical"
         android:gravity="center"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content">
         <EditText
            android:id="@+id/tfHundreds"
            android:layout_width="72dp"
            android:layout_height="58dp"
            android:background="@drawable/dialog_time_field"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:maxLength="3"
            style="@style/NumericEditText"/>
         <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/time_unit_ms"
            android:textColor="@color/secondary_text"
            android:textSize="11sp"/>
      </LinearLayout>

   </LinearLayout>

   <!-- DNF toggle: tapping anywhere on the row flips the switch (wired up in code). -->
   <LinearLayout
      android:id="@+id/llDNFRow"
      android:orientation="horizontal"
      android:gravity="center_vertical"
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:layout_marginTop="22dp"
      android:background="@drawable/dialog_toggle_row"
      android:paddingLeft="16dp"
      android:paddingRight="12dp"
      android:paddingTop="6dp"
      android:paddingBottom="6dp">

      <TextView
         android:layout_width="0dp"
         android:layout_height="wrap_content"
         android:layout_weight="1"
         android:layout_marginEnd="20dp"
         android:text="@string/DNF"
         android:textColor="@color/white"
         android:textSize="16sp"/>

      <androidx.appcompat.widget.SwitchCompat
         android:id="@+id/cbDNF"
         android:layout_width="wrap_content"
         android:layout_height="wrap_content"
         android:clickable="false"
         android:focusable="false"
         app:thumbTint="@color/lightblue"
         app:trackTint="@color/iceblue"/>

   </LinearLayout>

</LinearLayout>
