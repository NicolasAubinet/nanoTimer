<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
   xmlns:app="http://schemas.android.com/apk/res-auto"
   android:id="@+id/mainLayout"
   android:fitsSystemWindows="true"
   android:layout_height="match_parent"
   android:layout_width="match_parent"
   android:orientation="vertical">

  <androidx.drawerlayout.widget.DrawerLayout
     android:id="@+id/drawerLayout"
     android:layout_width="match_parent"
     android:layout_height="match_parent">

    <RelativeLayout
       android:layout_width="match_parent"
       android:layout_height="wrap_content"
       android:background="@color/graybg">

      <LinearLayout
         android:orientation="vertical"
         android:layout_alignParentTop="true"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:layout_above="@+id/buStart">

        <com.google.android.material.appbar.AppBarLayout
           android:layout_width="match_parent"
           android:layout_height="wrap_content"> <!-- for the elevation shadow -->
          <androidx.appcompat.widget.Toolbar
             android:id="@+id/toolbar"
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:background="@color/color_primary"
             app:titleTextAppearance="@style/Toolbar.CustomTitleText"/>
        </com.google.android.material.appbar.AppBarLayout>

        <androidx.cardview.widget.CardView
           android:id="@+id/layoutTop"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:layout_marginTop="@dimen/space_s"
           android:layout_marginBottom="@dimen/space_xs"
           android:layout_marginLeft="@dimen/space_m"
           android:layout_marginRight="@dimen/space_m"
           app:cardBackgroundColor="@color/mainscreen_top_card"
           app:cardElevation="@dimen/mainscreen_card_elevation"
           app:cardCornerRadius="@dimen/card_corner">

          <TableLayout
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:stretchColumns="*"
             android:paddingLeft="@dimen/space_s"
             android:paddingRight="@dimen/space_s"
             android:paddingTop="@dimen/space_m"
             android:paddingBottom="@dimen/space_s">

            <TableRow>

              <TextView
                 android:layout_width="0dp"
                 android:layout_height="wrap_content"
                 android:layout_marginLeft="@dimen/space_xs"
                 android:text="@string/cube_type"
                 android:gravity="start"
                 style="@style/SelectorLabel"/>

              <TextView
                 android:layout_width="0dp"
                 android:layout_height="wrap_content"
                 android:layout_marginLeft="@dimen/space_xs"
                 android:text="@string/solve_type"
                 android:gravity="start"
                 style="@style/SelectorLabel"/>
            </TableRow>

            <TableRow>

              <Spinner
                 android:id="@+id/spCubeType"
                 android:layout_width="0dp"
                 android:gravity="start"
                 style="@style/CustomSpinner"/>

              <Spinner
                 android:id="@+id/spSolveType"
                 android:layout_width="0dp"
                 android:gravity="start"
                 style="@style/CustomSpinner"/>

            </TableRow>

          </TableLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
           android:id="@+id/layoutHistory"
           android:layout_width="match_parent"
           android:layout_height="match_parent"
           android:orientation="vertical">

          <androidx.cardview.widget.CardView
             android:layout_width="match_parent"
             android:layout_height="wrap_content"
             android:layout_marginTop="@dimen/space_xs"
             android:layout_marginBottom="@dimen/space_xs"
             android:layout_marginLeft="@dimen/space_m"
             android:layout_marginRight="@dimen/space_m"
             app:cardBackgroundColor="@color/button_color"
             app:cardElevation="@dimen/mainscreen_card_elevation"
             app:cardCornerRadius="@dimen/card_corner">

            <RelativeLayout
               android:layout_width="match_parent"
               android:layout_height="wrap_content"
               android:paddingTop="@dimen/space_s"
               android:paddingLeft="@dimen/space_m"
               android:paddingRight="@dimen/space_m"
               android:paddingBottom="@dimen/space_s">

              <TextView
                 android:id="@+id/tvHistory"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:text="@string/history"
                 android:textStyle="bold"
                 android:letterSpacing="0.02"
                 android:layout_alignParentStart="true"
                 android:layout_alignParentLeft="true"
                 android:layout_centerVertical="true"
                 style="@style/SimpleTextField"/>

              <TextView
                 android:id="@+id/tvSolvesCount"
                 android:layout_width="wrap_content"
                 android:layout_height="wrap_content"
                 android:textColor="@color/secondary_text"
                 android:layout_alignParentRight="true"
                 android:layout_alignParentEnd="true"
                 android:layout_centerVertical="true"
                 style="@style/SmallTextField"/>
            </RelativeLayout>

          </androidx.cardview.widget.CardView>

          <ListView
             android:id="@+id/lvHistory"
             android:layout_width="match_parent"
             android:layout_height="match_parent"
             android:alwaysDrawnWithCache="false"
             style="@style/ListView"/>
          <!--android:background="@color/listview_background"-->

        </LinearLayout>

      </LinearLayout>

      <!--</android.support.v7.widget.CardView>-->

      <!--<FrameLayout
         android:id="@+id/startButtonLayout"
         android:layout_width="match_parent"
         android:layout_height="wrap_content"
         android:background="@color/color_primary"
         android:layout_alignParentBottom="true">-->
      <androidx.appcompat.widget.AppCompatButton
         android:id="@+id/buStart"
         android:text="@string/start"
         android:layout_alignParentBottom="true"
         android:layout_marginLeft="@dimen/space_m"
         android:layout_marginRight="@dimen/space_m"
         android:layout_marginTop="@dimen/space_s"
         android:layout_marginBottom="@dimen/space_s"
         style="@style/PrimaryButton"/>
      <!--android:background="@drawable/button_selector"-->
      <!--android:layout_marginLeft="@dimen/mainscreen_margin"-->
      <!--android:layout_marginRight="@dimen/mainscreen_margin"-->

      <!--android:background="?android:attr/selectableItemBackground"-->
      <!--android:layout_marginLeft="2dp"-->
      <!--android:layout_marginRight="2dp"-->
      <!--</FrameLayout>-->

    </RelativeLayout>

    <com.google.android.material.navigation.NavigationView
       android:id="@+id/navigationView"
       android:layout_width="wrap_content"
       android:layout_height="match_parent"
       android:layout_gravity="start">

      <include layout="@layout/mainscreen_drawer_menu"/>
    </com.google.android.material.navigation.NavigationView>

  </androidx.drawerlayout.widget.DrawerLayout>

</LinearLayout>
