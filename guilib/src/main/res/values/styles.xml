<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:android="http://schemas.android.com/apk/res/android">

  <style name="Toolbar.TitleText" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
    <item name="android:textSize">18sp</item>
  </style>

  <style name="SimpleTextField">
    <item name="android:textSize">20sp</item>
  </style>

  <style name="SmallTextField">
    <item name="android:textSize">16sp</item>
    <item name="android:ellipsize">end</item>
  </style>

  <!-- All-caps, letter-spaced section label used across the redesigned dialogs. -->
  <style name="DialogSectionLabel">
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:textAllCaps">true</item>
    <item name="android:textColor">@color/secondary_text</item>
    <item name="android:textSize">12sp</item>
    <item name="android:letterSpacing">0.08</item>
  </style>

  <!-- Quiet accent section label for the main-screen selector card. -->
  <style name="SelectorLabel" parent="DialogSectionLabel">
    <item name="android:textColor">@color/lightblue</item>
  </style>

  <style name="SmallTextFieldPx">
    <item name="android:textSize">21px</item>
    <item name="android:ellipsize">end</item>
    <item name="android:singleLine">true</item>
    <item name="android:textColor">@color/secondary_text</item> <!-- muted stat labels; values override to white -->
  </style>

  <style name="SolveStepTextFieldPx">
    <item name="android:textSize">24px</item>
    <item name="android:gravity">center</item>
    <item name="android:layout_weight">1</item>
    <item name="android:layout_width">0px</item>
    <item name="android:layout_marginLeft">2px</item>
    <item name="android:layout_marginRight">2px</item>
    <item name="android:singleLine">true</item>
    <item name="android:textColor">@color/white</item>
  </style>

  <!-- Multi-step timing rows: muted step labels, bold tabular step times. -->
  <style name="SolveStepLabelPx" parent="SolveStepTextFieldPx">
    <item name="android:textColor">@color/secondary_text</item>
  </style>

  <style name="SolveStepValuePx" parent="SolveStepTextFieldPx">
    <item name="android:textStyle">bold</item>
    <item name="android:fontFeatureSettings">tnum</item>
  </style>

  <style name="TableCell">
    <item name="android:textSize">15sp</item>
    <item name="android:gravity">center</item>
    <item name="android:layout_height">22dp</item>
    <item name="android:layout_width">0dp</item>
    <item name="android:padding">1dp</item>
    <item name="android:layout_weight">1</item>
    <item name="android:textColor">@color/white</item>
  </style>

  <style name="TableCellPx" parent="TableCell">
    <item name="android:textSize">21px</item>
    <item name="android:layout_height">33px</item>
    <item name="android:padding">2px</item>
    <item name="android:fontFeatureSettings">tnum</item> <!-- tabular figures so time columns align -->
  </style>

  <style name="GridCell" parent="TableCell">
    <item name="android:layout_width">0dp</item>
    <item name="layout_columnWeight">1</item>
    <!--<item name="gravity">center</item>-->
  </style>

  <style name="GridCellPx" parent="TableCellPx">
    <item name="android:layout_width">0px</item>
    <item name="layout_columnWeight">1</item>
    <item name="android:layout_margin">3px</item> <!-- gap between recent-solve chips -->
    <!--<item name="gravity">center</item>-->
  </style>

  <style name="EqualSizeColumnsTable">
    <item name="android:shrinkColumns">*</item>
    <item name="android:stretchColumns">*</item>
  </style>

  <style name="AverageTableHeaderField" parent="TableCell">
    <item name="android:textColor">@color/lightblue</item>
    <item name="android:background">@color/table_header</item>
    <item name="android:textStyle">bold</item>
  </style>

  <style name="AverageTableHeaderFieldPx" parent="TableCellPx">
    <item name="android:textColor">@color/lightblue</item>
    <item name="android:background">@color/transparent</item> <!-- softened: cyan text, no bar -->
    <item name="android:textStyle">bold</item>
  </style>

  <style name="AverageTableFirstFieldPx" parent="AverageTableHeaderFieldPx">
    <item name="android:layout_width">40px</item>
  </style>

  <style name="ListView">
    <item name="android:divider">@color/listview_divider</item>
    <item name="android:dividerHeight">2px</item>
  </style>

  <style name="ListViewItem">
    <item name="android:textSize">18sp</item>
    <item name="android:layout_width">wrap_content</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:layout_marginTop">4dp</item>
    <item name="android:layout_marginBottom">4dp</item>
    <item name="android:singleLine">true</item>
    <item name="android:padding">2dp</item>
  </style>

  <style name="SmallListViewItem">
    <item name="android:textSize">16sp</item>
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:padding">7dp</item>
  </style>

  <style name="SpinnerTextView">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:maxLines">1</item>
    <item name="android:textSize">18sp</item>
    <item name="android:gravity">start</item>
    <item name="android:padding">8dp</item>
    <item name="android:textColor">@color/secondary_text</item>
    <item name="android:ellipsize">marquee</item>
  </style>

  <style name="CustomButton">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <item name="android:textSize">14sp</item>
    <item name="android:padding">2dp</item>
    <item name="android:gravity">center</item>
    <item name="android:textColor">@color/white</item>
    <item name="android:singleLine">true</item>
    <item name="android:textAllCaps">false</item>
  </style>

  <style name="BigButton" parent="CustomButton">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">55dp</item>
    <item name="android:textSize">18sp</item>
    <item name="android:background">@drawable/button_ripple</item>
  </style>

  <!-- Primary call-to-action (Start, Export, dialog Close): taller, more rounded,
       bolder than the generic BigButton. -->
  <style name="PrimaryButton" parent="BigButton">
    <item name="android:layout_height">60dp</item>
    <item name="android:textSize">19sp</item>
    <item name="android:textStyle">bold</item>
    <item name="android:letterSpacing">0.04</item>
    <item name="android:background">@drawable/primary_button_ripple</item>
  </style>

  <!-- Rounded tonal action button used in dialogs (+2 / DNF / Delete). -->
  <style name="DialogActionButton" parent="CustomButton">
    <item name="android:layout_height">44dp</item>
    <item name="android:textSize">15sp</item>
    <item name="android:background">@drawable/dialog_action_button</item>
  </style>

  <style name="CustomSpinner">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">wrap_content</item>
    <!--<item name="android:background">@color/spinner_background</item>-->
    <item name="android:paddingLeft">2dp</item>
    <item name="android:paddingRight">2dp</item>
    <item name="android:gravity">center</item>
    <item name="android:singleLine">true</item>
    <item name="android:textAllCaps">false</item>
    <item name="android:popupBackground">@color/darkblue</item>
  </style>

  <style name="TableCardView">
    <!--<item name="android:layout_marginTop">2dp</item>-->
    <!--<item name="android:layout_marginBottom">2dp</item>-->
    <item name="android:layout_marginLeft">4dp</item>
    <item name="android:layout_marginRight">4dp</item>
    <item name="cardBackgroundColor">@color/timercardbg</item>
    <item name="cardCornerRadius">8dp</item>
    <item name="cardElevation">2dp</item>
  </style>

  <style name="TableCardViewPx" parent="TableCardView">
    <!--<item name="android:layout_marginTop">2px</item>-->
    <!--<item name="android:layout_marginBottom">2px</item>-->
    <item name="android:layout_marginLeft">@dimen/grid_margin_px</item>
    <item name="android:layout_marginRight">@dimen/grid_margin_px</item>
    <item name="cardCornerRadius">8dp</item>
    <item name="cardElevation">2dp</item>
  </style>

  <style name="ScrambleTextField">
    <item name="android:textSize">12sp</item>
    <item name="android:gravity">center</item>
  </style>

  <style name="ScrambleTextFieldPx" parent="ScrambleTextField">
    <item name="android:textSize">18px</item>
  </style>

  <style name="DividerRow">
    <item name="android:layout_width">match_parent</item>
    <item name="android:layout_height">3px</item>
    <item name="android:background">@color/iceblue</item>
  </style>

  <style name="NumericWheelView">
    <item name="android:layout_width">55dp</item>
    <item name="android:layout_height">80dp</item>
  </style>

  <style name="NumericEditText">
    <item name="android:inputType">number</item>
    <item name="android:gravity">center</item>
    <item name="android:textSize">20sp</item>
  </style>

</resources>